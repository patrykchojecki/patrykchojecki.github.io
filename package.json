{
  "name": "patrykchojecki.github.io",
  "version": "1.0.0",
  "private": true,
  "description": "Build tooling for chojecki.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrykchojecki/patrykchojecki.github.io.git"
  },
  "keywords": [
    "jekyll",
    "github-pages",
    "personal-site"
  ],
  "author": "Patryk Chojecki",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/patrykchojecki/patrykchojecki.github.io/issues"
  },
  "homepage": "https://chojecki.net/",
  "engines": {
    "node": ">=26.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "npm-run-all2": "^9.0.2",
    "onchange": "^7.1.0",
    "terser": "^5.39.0"
  },
  "scripts": {
    "build": "run-s build:js build:site",
    "build:site": "JEKYLL_ENV=production bundle exec jekyll build",
    "check": "npm run build",
    "serve": "bundle exec jekyll serve --config _config.yml,_config.dev.yml --host 127.0.0.1 --port 4001",
    "serve:prod": "JEKYLL_ENV=production bundle exec jekyll serve --host 127.0.0.1 --port 4001",
    "uglify": "terser assets/js/_main.js -c -m -o assets/js/main.min.js",
    "watch:js": "onchange \"assets/js/**/*.js\" -e \"assets/js/main.min.js\" -- npm run build:js",
    "build:js": "npm run uglify"
  }
}
